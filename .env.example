# CS2 Analytics — required environment variables
# Copy this file to .env and fill in your actual credentials.
# Never commit .env to version control.

# FACEIT Data API v4 — https://developers.faceit.com/docs/auth/oauth
CS2_FACEIT_API_KEY=your_faceit_api_key_here

# PandaScore API — https://developers.pandascore.co/
CS2_PANDASCORE_API_KEY=your_pandascore_api_key_here

# Liquipedia REST API v3 — https://liquipedia.net/api
CS2_LIQUIPEDIA_API_KEY=your_liquipedia_api_key_here

# AWS S3 bucket name where raw Parquet partitions are written
CS2_AWS_S3_BUCKET=your-s3-bucket-name

# AWS region for S3 client (defaults to us-east-1 if not set)
CS2_AWS_REGION=us-east-1

# Kaggle credentials — https://www.kaggle.com/settings (API section)
CS2_KAGGLE_USERNAME=your_kaggle_username
CS2_KAGGLE_KEY=your_kaggle_api_key_here

# ── Airflow ──────────────────────────────────────────────────────────────────
# Generate Fernet key once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CS2_AIRFLOW_FERNET_KEY=

# Random string for Airflow webserver session signing (any random value works for dev)
CS2_AIRFLOW_SECRET_KEY=dev_secret_change_me

# Slack Incoming Webhook URL for DAG failure alerts
# Create at: https://api.slack.com/messaging/webhooks
CS2_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Linux only: prevents volume permission issues (run: echo "AIRFLOW_UID=$(id -u)" >> .env)
AIRFLOW_UID=50000

# ── Snowflake (Phase 3 — key-pair auth, NOT password) ────────────────────────
# Account identifier format: orgname-accountname (from Snowflake Admin > Accounts page)
# For legacy trial accounts: locator.region.cloud (e.g., abc1234.us-east-1.aws)
SNOWFLAKE_ACCOUNT=orgname-accountname

# Service user name configured with RSA public key
SNOWFLAKE_USER=cs2_service_user

# Full PEM private key content (newlines as \n)
# Generate: openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -nocrypt
# Register pub key: ALTER USER cs2_service_user SET RSA_PUBLIC_KEY='<pub_key_without_headers>';
SNOWFLAKE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Warehouse name created by dbt_project/setup/snowflake_setup.sql
SNOWFLAKE_WAREHOUSE=CS2_WH

# Database name created by snowflake_setup.sql
SNOWFLAKE_DATABASE=CS2_ANALYTICS
